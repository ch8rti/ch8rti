<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Влад — видеомонтажёр</title>

  <style>
    :root{
      --bg:#050b13;
      --bg2:#071625;
      --card:rgba(17,27,39,.72);
      --card-2:rgba(12,20,32,.88);
      --line:rgba(255,255,255,.08);
      --text:#f4f7fb;
      --muted:#aebdcc;
      --blue:#1f80ff;
      --blue2:#52a1ff;
      --blueGlow:rgba(31,128,255,.30);
      --shadow:0 20px 50px rgba(0,0,0,.35);
      --radius:24px;
      --container:1220px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at 20% 18%, rgba(18,96,189,.20), transparent 24%),
        radial-gradient(circle at 78% 30%, rgba(18,96,189,.12), transparent 18%),
        radial-gradient(circle at 50% 80%, rgba(18,96,189,.08), transparent 26%),
        linear-gradient(180deg,#030811 0%,#04111d 34%,#02070d 100%);
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background-image:
        radial-gradient(circle at 10% 20%, rgba(255,255,255,.06) 0 1px, transparent 1px),
        radial-gradient(circle at 70% 40%, rgba(255,255,255,.05) 0 1px, transparent 1px),
        radial-gradient(circle at 40% 80%, rgba(255,255,255,.04) 0 1px, transparent 1px);
      background-size:220px 220px, 280px 280px, 320px 320px;
      animation:bgFloat 18s linear infinite;
      opacity:.45;
    }

    @keyframes bgFloat{
      0%{transform:translateY(0)}
      50%{transform:translateY(-12px)}
      100%{transform:translateY(0)}
    }

    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}

    .container{
      width:min(var(--container), calc(100% - 44px));
      margin:0 auto;
    }

    .site-header{
      position:sticky;
      top:0;
      z-index:50;
      backdrop-filter:blur(14px);
      background:rgba(3,9,16,.48);
      border-bottom:1px solid rgba(255,255,255,.05);
    }

    .nav{
      min-height:78px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
    }

    .brand{
      font-size:34px;
      font-weight:800;
      letter-spacing:-0.04em;
    }

    .nav-links{
      display:flex;
      gap:34px;
      color:#dbe7f4;
    }

    .nav-links a{
      position:relative;
      font-size:17px;
    }

    .nav-links a::after{
      content:"";
      position:absolute;
      left:0;
      bottom:-8px;
      width:0;
      height:2px;
      background:linear-gradient(90deg,var(--blue2),transparent);
      transition:width .25s ease;
    }

    .nav-links a:hover::after{
      width:100%;
    }

    .cta{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      height:52px;
      padding:0 28px;
      border-radius:14px;
      background:linear-gradient(180deg, var(--blue2), var(--blue));
      color:#fff;
      font-weight:700;
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 10px 24px rgba(31,128,255,.22);
      transition:transform .2s ease, box-shadow .25s ease, opacity .2s ease;
    }

    .cta:hover{
      transform:translateY(-2px);
      box-shadow:0 18px 34px rgba(31,128,255,.32);
      opacity:.98;
    }

    .hero{
      position:relative;
      min-height:760px;
      padding:76px 0 100px;
      display:grid;
      grid-template-columns:1.08fr .92fr;
      gap:50px;
      align-items:center;
    }

    .hero-copy{
      position:relative;
      z-index:2;
    }

    h1{
      margin:0 0 16px;
      font-size:72px;
      line-height:1.02;
      letter-spacing:-0.05em;
      max-width:760px;
    }

    .lead{
      margin:0 0 28px;
      max-width:780px;
      font-size:29px;
      line-height:1.28;
      color:#edf3fb;
    }

    .stats{
      display:flex;
      width:min(740px,100%);
      overflow:hidden;
      border-radius:20px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(17,27,39,.75);
      box-shadow:var(--shadow);
      margin:8px 0 28px;
    }

    .stat{
      flex:1;
      padding:22px 26px 18px;
      border-right:1px solid rgba(255,255,255,.06);
      transition:background .25s ease;
    }

    .stat:last-child{border-right:none}
    .stat:hover{background:rgba(255,255,255,.02)}

    .stat .label{
      color:#95a8bd;
      text-transform:uppercase;
      font-size:14px;
      letter-spacing:.08em;
      margin-bottom:10px;
    }

    .stat .value{
      color:var(--blue2);
      font-size:62px;
      font-weight:800;
      line-height:1;
      letter-spacing:-0.06em;
      margin-bottom:10px;
      text-shadow:0 0 20px rgba(46,139,255,.18);
    }

    .stat .sub{
      font-size:21px;
      line-height:1.2;
      color:#eaf0f8;
    }

    .hero-visual{
      position:relative;
      height:620px;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .ring{
      width:420px;
      height:420px;
      border-radius:50%;
      border:4px solid rgba(255,255,255,.78);
      box-shadow:0 0 40px rgba(255,255,255,.18), inset 0 0 32px rgba(255,255,255,.04);
      opacity:.92;
      animation:ringPulse 4s ease-in-out infinite;
    }

    @keyframes ringPulse{
      0%,100%{transform:scale(1); box-shadow:0 0 40px rgba(255,255,255,.18), inset 0 0 32px rgba(255,255,255,.04)}
      50%{transform:scale(1.03); box-shadow:0 0 54px rgba(31,128,255,.18), inset 0 0 40px rgba(255,255,255,.06)}
    }

    .app{
      position:absolute;
      width:210px;
      height:210px;
      border-radius:34px;
      background:linear-gradient(180deg,#1d2b88,#0b0a84);
      border:2px solid rgba(255,255,255,.16);
      box-shadow:0 26px 42px rgba(0,0,0,.34);
      display:flex;
      align-items:center;
      justify-content:center;
      user-select:none;
    }

    .app span{
      font-size:106px;
      font-weight:800;
      letter-spacing:-0.06em;
      color:#a6a3ff;
    }

    .app.ae{
      top:84px;
      left:82px;
      animation:float1 5s ease-in-out infinite;
    }

    .app.pr{
      bottom:98px;
      right:82px;
      animation:float2 5.8s ease-in-out infinite;
    }

    @keyframes float1{
      0%,100%{transform:translateY(0) rotate(-2deg)}
      50%{transform:translateY(-14px) rotate(2deg)}
    }

    @keyframes float2{
      0%,100%{transform:translateY(0) rotate(2deg)}
      50%{transform:translateY(14px) rotate(-2deg)}
    }

    section{padding:34px 0}
    .section-title{
      margin:0 0 20px;
      font-size:46px;
      letter-spacing:-0.04em;
    }

    .cards{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:24px;
    }

    .card{
      position:relative;
      background:var(--card);
      border:1px solid var(--line);
      border-radius:24px;
      overflow:hidden;
      box-shadow:var(--shadow);
      transition:transform .25s ease, border-color .25s ease, box-shadow .25s ease;
      isolation:isolate;
    }

    .card::before{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:24px;
      padding:1px;
      background:linear-gradient(135deg, rgba(82,161,255,.0), rgba(82,161,255,.65), rgba(82,161,255,0));
      -webkit-mask:
        linear-gradient(#000 0 0) content-box,
        linear-gradient(#000 0 0);
      -webkit-mask-composite:xor;
              mask-composite:exclude;
      opacity:0;
      transition:opacity .28s ease;
      pointer-events:none;
    }

    .card:hover{
      transform:translateY(-6px);
      box-shadow:0 26px 54px rgba(0,0,0,.42), 0 0 34px rgba(31,128,255,.10);
      border-color:rgba(82,161,255,.18);
    }

    .card:hover::before{
      opacity:1;
    }

    .card .meta{
      padding:16px 18px 0;
      color:#8fa0b2;
      font-size:14px;
      text-transform:uppercase;
      letter-spacing:.05em;
    }

    .video-preview{
      position:relative;
      margin:12px 12px 0;
      aspect-ratio:16/9;
      overflow:hidden;
      border-radius:20px;
      background:#111827;
      cursor:pointer;
      box-shadow:inset 0 -60px 80px rgba(0,0,0,.28);
    }

    .video-preview iframe,
    .video-preview img{
      width:100%;
      height:100%;
      display:block;
      object-fit:cover;
      border:0;
    }

    .video-preview::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(180deg, rgba(0,0,0,.06), rgba(0,0,0,.22)),
        radial-gradient(circle at center, rgba(31,128,255,.10), transparent 44%);
      pointer-events:none;
      transition:opacity .25s ease;
    }

    .card:hover .video-preview::after{
      background:
        linear-gradient(180deg, rgba(0,0,0,.02), rgba(0,0,0,.18)),
        radial-gradient(circle at center, rgba(31,128,255,.18), transparent 44%);
    }

    .play-overlay{
      position:absolute;
      inset:0;
      display:flex;
      align-items:center;
      justify-content:center;
      z-index:2;
      transition:transform .25s ease, opacity .25s ease;
    }

    .play-btn{
      position:relative;
      width:82px;
      height:82px;
      border-radius:50%;
      background:rgba(8,17,30,.72);
      border:1px solid rgba(255,255,255,.14);
      backdrop-filter:blur(8px);
      box-shadow:0 12px 30px rgba(0,0,0,.30), 0 0 0 0 rgba(31,128,255,.35);
      display:flex;
      align-items:center;
      justify-content:center;
      transition:transform .25s ease, box-shadow .25s ease;
    }

    .play-btn::before{
      content:"";
      position:absolute;
      inset:-10px;
      border-radius:50%;
      border:1px solid rgba(82,161,255,.25);
      animation:pulsePlay 2.2s ease-out infinite;
    }

    .play-btn::after{
      content:"";
      margin-left:5px;
      border-style:solid;
      border-width:13px 0 13px 22px;
      border-color:transparent transparent transparent #fff;
    }

    @keyframes pulsePlay{
      0%{transform:scale(.92); opacity:.75}
      70%{transform:scale(1.16); opacity:0}
      100%{transform:scale(1.16); opacity:0}
    }

    .video-preview:hover .play-btn{
      transform:scale(1.07);
      box-shadow:0 16px 36px rgba(0,0,0,.36), 0 0 0 10px rgba(31,128,255,.08);
    }

    .video-preview.playing .play-overlay{
      opacity:0;
      pointer-events:none;
    }

    .video-preview.playing img{
      display:none;
    }

    .duration-badge{
      position:absolute;
      left:14px;
      bottom:14px;
      z-index:2;
      padding:8px 11px;
      border-radius:12px;
      background:rgba(8,14,24,.68);
      border:1px solid rgba(255,255,255,.10);
      color:#fff;
      font-size:13px;
      font-weight:600;
      backdrop-filter:blur(8px);
    }

    .card-body{
      padding:18px;
    }

    .card-title{
      margin:0 0 12px;
      font-size:22px;
      line-height:1.18;
      letter-spacing:-0.03em;
      min-height:84px;
    }

    .video-link{
      display:inline-block;
      margin-bottom:14px;
      color:#cfe2ff;
      font-weight:700;
      transition:color .2s ease, transform .2s ease;
    }

    .video-link:hover{
      color:#fff;
      transform:translateX(3px);
    }

    .video-stats{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }

    .stat-chip{
      padding:10px 14px;
      border-radius:12px;
      font-size:14px;
      color:#c8d5e3;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      transition:background .2s ease, transform .2s ease;
    }

    .stat-chip:hover{
      background:rgba(31,128,255,.12);
      transform:translateY(-1px);
    }

    .about-card{
      position:relative;
      background:var(--card);
      border:1px solid var(--line);
      border-radius:24px;
      box-shadow:var(--shadow);
      padding:34px;
      max-width:980px;
      overflow:hidden;
    }

    .about-card::after{
      content:"";
      position:absolute;
      top:-80px;
      right:-80px;
      width:220px;
      height:220px;
      background:radial-gradient(circle, rgba(31,128,255,.16), transparent 66%);
      pointer-events:none;
    }

    .about-card h3{
      margin:0 0 16px;
      font-size:40px;
      letter-spacing:-0.04em;
    }

    .about-card p{
      margin:0 0 16px;
      color:#d8e1ea;
      font-size:22px;
      line-height:1.45;
    }

    .reviews{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:20px;
    }

    .review{
      position:relative;
      background:var(--card-2);
      border:1px solid var(--line);
      border-radius:24px;
      padding:22px;
      box-shadow:var(--shadow);
      overflow:hidden;
      transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

    .review::before{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(90deg, rgba(31,128,255,.08), transparent 40%, transparent 60%, rgba(31,128,255,.08));
      opacity:0;
      transition:opacity .25s ease;
      pointer-events:none;
    }

    .review:hover{
      transform:translateY(-6px);
      border-color:rgba(82,161,255,.18);
      box-shadow:0 26px 54px rgba(0,0,0,.42), 0 0 34px rgba(31,128,255,.10);
    }

    .review:hover::before{
      opacity:1;
    }

    .review-label{
      color:#9aa3af;
      font-size:14px;
      text-transform:uppercase;
      margin-bottom:14px;
    }

    .review-head{
      display:flex;
      align-items:flex-start;
      gap:16px;
    }

    .review-avatar{
      width:62px;
      height:62px;
      flex:0 0 62px;
      border-radius:50%;
      border:1px solid rgba(255,255,255,.08);
      background:
        radial-gradient(circle at 50% 32%, #d7e3ee 0 8px, transparent 9px),
        radial-gradient(ellipse at 50% 74%, #d7e3ee 0 16px, transparent 17px),
        linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
      box-shadow:inset 0 0 22px rgba(255,255,255,.03);
      position:relative;
      overflow:hidden;
    }

    .review-avatar::after{
      content:"";
      position:absolute;
      inset:-1px;
      border-radius:50%;
      box-shadow:0 0 0 1px rgba(255,255,255,.04), 0 0 18px rgba(31,128,255,.10);
    }

    .review-name{
      margin:0 0 6px;
      font-size:20px;
      font-weight:700;
    }

    .review-text{
      margin:0;
      color:#e3e8ef;
      font-size:16px;
      line-height:1.35;
    }

    footer{
      margin-top:54px;
      border-top:1px solid rgba(255,255,255,.06);
      background:rgba(2,8,14,.55);
    }

    .footer-inner{
      min-height:92px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:20px;
      flex-wrap:wrap;
      color:#c6d1dd;
    }

    .footer-links{
      display:flex;
      gap:20px;
      flex-wrap:wrap;
    }

    @media (max-width:1180px){
      h1{font-size:58px}
      .lead{font-size:25px}
      .stat .value{font-size:52px}
      .stat .sub{font-size:19px}
      .reviews{grid-template-columns:1fr}
    }

    @media (max-width:980px){
      .nav{min-height:70px}
      .nav-links{display:none}
      .hero{
        grid-template-columns:1fr;
        min-height:auto;
        padding-top:38px;
      }
      .hero-visual{height:420px}
      .ring{width:290px;height:290px}
      .app{width:156px;height:156px}
      .app span{font-size:78px}
      .app.ae{top:38px;left:calc(50% - 150px)}
      .app.pr{bottom:42px;right:calc(50% - 150px)}
      .cards{grid-template-columns:1fr}
    }

    @media (max-width:640px){
      .container{width:min(var(--container), calc(100% - 28px))}
      h1{font-size:44px}
      .lead{font-size:19px}
      .stats{flex-direction:column}
      .stat{
        border-right:none;
        border-bottom:1px solid rgba(255,255,255,.07);
      }
      .stat:last-child{border-bottom:none}
      .stat .value{font-size:44px}
      .stat .sub{font-size:18px}
      .section-title{font-size:34px}
      .about-card p{font-size:18px}
      .brand{font-size:28px}
      .cta{height:48px;padding:0 22px}
      .card-title{min-height:auto}
    }
  </style>
</head>
