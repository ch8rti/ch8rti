  <script>
    const previews = document.querySelectorAll('.video-preview');

    previews.forEach(preview => {
      preview.addEventListener('click', () => {
        if (preview.classList.contains('playing')) return;

        const videoId = preview.dataset.videoId;
        const start = preview.dataset.start || 0;
        const end = preview.dataset.end || 90;

        const iframe = document.createElement('iframe');
        iframe.src =
          `https://www.youtube.com/embed/${videoId}?autoplay=1&mute=0&rel=0&modestbranding=1&start=${start}&end=${end}`;
        iframe.title = 'YouTube video player';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.allowFullscreen = true;

        preview.classList.add('playing');
        preview.appendChild(iframe);
      });
    });
  </script>

